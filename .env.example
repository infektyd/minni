# Sovereign Memory configuration
# Copy to .env and customize

# Data directory (defaults to ~/.sovereign/, falls back to ~/.openclaw/)
# SOVEREIGN_HOME=~/.sovereign

# Override individual paths (optional — defaults derive from SOVEREIGN_HOME)
# SOVEREIGN_DB_PATH=~/.sovereign/sovereign_memory.db
# SOVEREIGN_FAISS_PATH=~/.sovereign/sovereign_faiss.index
# SOVEREIGN_GRAPH_DIR=~/.sovereign/graphs/
# SOVEREIGN_WRITEBACK_PATH=~/.sovereign/learnings/
# SOVEREIGN_VAULT_PATH=~/obsidian/openClaw/

# Opt-in AFM provider mode for Python retrieval helpers and the TypeScript plugin:
# bridge = existing localhost OpenAI-compatible bridge
# native = local FoundationModels helper
# auto = native when available, otherwise bridge
# off = skip AFM calls
# SOVEREIGN_AFM_PROVIDER_MODE=bridge
# Legacy alias for Python-only scripts:
# SOVEREIGN_AFM_MODE=bridge
# SOVEREIGN_AFM_NATIVE_HELPER=/path/to/sovereignMemory/engine/native_afm_helper
# Optional future adapter metadata only. Status reports whether an adapter is
# configured but does not expose this path.
# SOVEREIGN_AFM_ADAPTER_PATH=/path/to/private/model.fmadapter

# TypeScript plugin prepare-task/outcome bridge defaults.
# SOVEREIGN_AFM_HEALTH_URL=http://127.0.0.1:11437/health
# SOVEREIGN_AFM_PREPARE_TASK_URL=http://127.0.0.1:11437/v1/chat/completions
