# Minni configuration
# Copy to .env and customize

# Data directory (defaults to ~/.minni/)
# MINNI_HOME=~/.minni

# Override individual paths (optional — defaults derive from MINNI_HOME)
# MINNI_DB_PATH=~/.minni/minni.db
# MINNI_FAISS_PATH=~/.minni/faiss/index.faiss
# MINNI_GRAPH_DIR=~/.minni/graphs/
# MINNI_WRITEBACK_PATH=~/.minni/learnings/
# MINNI_VAULT_PATH=~/.minni/vault
# Plugin/client socket override. The Python daemon startup path uses
# `make daemon SOCKET=...` or `engine/minnid.py --socket ...`.
# MINNI_SOCKET_PATH=~/.minni/run/minnid.sock

# Opt-in AFM provider mode for Python retrieval helpers and the TypeScript plugin:
# bridge = existing localhost OpenAI-compatible bridge
# native = local FoundationModels helper
# auto = native when available, otherwise bridge
# off = skip AFM calls
# MINNI_AFM_PROVIDER_MODE=bridge
# Legacy alias for Python-only scripts:
# MINNI_AFM_MODE=bridge
# MINNI_AFM_NATIVE_HELPER=/path/to/Minni/engine/native_afm_helper
# Optional future adapter metadata only. Status reports whether an adapter is
# configured but does not expose this path.
# MINNI_AFM_ADAPTER_PATH=/path/to/private/model.fmadapter

# TypeScript plugin prepare-task/outcome bridge defaults.
# MINNI_AFM_HEALTH_URL=http://127.0.0.1:11437/health
# MINNI_AFM_PREPARE_TASK_URL=http://127.0.0.1:11437/v1/chat/completions
