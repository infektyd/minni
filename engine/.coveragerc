# Coverage config for the Minni engine.
#
# Usage (opt-in; not part of default pytest addopts so plain `pytest` stays fast):
#   cd engine && PYTHONPATH=. python -m pytest --cov=. --cov-report=term-missing
# or via the root Makefile:
#   make coverage
#
# The full engine suite loads embedding/FAISS models and is heavy. For a quick
# signal, scope it: `make coverage CHECK_PYTEST="test_obs.py test_pr11_observability.py"`.

[run]
branch = True
source = .
omit =
    test_*.py
    conftest.py
    .venv/*
    */site-packages/*

[report]
show_missing = True
skip_covered = False
# Conservative floor for the full suite. Kept well below typical coverage so it
# surfaces regressions without failing the current suite.
fail_under = 40

[html]
directory = .coverage_html
