# membench-local ignores (the repo-root .gitignore already covers _private/,
# reports/, and most build artifacts; this is bench-scoped belt-and-suspenders).
__pycache__/
*.pyc
.pytest_cache/
reports/
# never commit local throwaway daemon state if it ever lands under bench/
*.sock
*.index
*.db

# s2(a): frozen real-vault snapshots + raw labels are PRIVATE — belt-and-
# suspenders over the root `_private/` rule. These names must never be staged
# from a public-git path even if a writer is misconfigured to land under bench/.
_private/
**/_private/
corpus_real/
gold_real.jsonl
gold_drafts.jsonl
**/manifest.json
**/scrub_spans.jsonl
snapshot_*/
