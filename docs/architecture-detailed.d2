# ── Shared plugin layer ─────────────────────────────

plugin: Shared plugin layer {
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  style.border-radius: 12

  mcp: MCP server\nsovereign-memory {
    shape: rectangle
    style.fill: "#E1F5EE"
    style.stroke: "#5DCAA5"
    style.font-size: 13
    style.bold: true
  }
  tools: Tools (26 registered) {
    shape: rectangle
    style.fill: "#E1F5EE"
    style.stroke: "#5DCAA5"
    style.font-size: 12
    tooltip: "recall, prepare, learn, resolve, vault_write, compile, route, drill, export_pack, audit, handoff, ping, team, contradictions"
  }
  hooks: Hook envelopes {
    shape: rectangle
    style.fill: "#E1F5EE"
    style.stroke: "#5DCAA5"
    style.font-size: 12
    tooltip: "SessionStart, UserPromptSubmit, PreCompact, Stop"
  }
  console-api: Console API {
    shape: rectangle
    style.fill: "#E1F5EE"
    style.stroke: "#5DCAA5"
    style.font-size: 12
    tooltip: "health, status, prepare-task, prepare-outcome, audit-tail, candidates, resolve-candidate, deep-research"
  }
  policy-ts: Policy routing\nrouteMemoryIntent\nassessLearningQuality {
    shape: rectangle
    style.fill: "#E1F5EE"
    style.stroke: "#5DCAA5"
    style.font-size: 12
  }
  ping-ts: Agent ping contracts\nrequest · inbox · decide · status {
    shape: rectangle
    style.fill: "#E1F5EE"
    style.stroke: "#5DCAA5"
    style.font-size: 12
  }
  team-ts: Team coordination\nruntime · evidence · promotion {
    shape: rectangle
    style.fill: "#E1F5EE"
    style.stroke: "#5DCAA5"
    style.font-size: 12
  }

  mcp -> tools
  mcp -> hooks
  mcp -> console-api
  tools -> policy-ts
  tools -> ping-ts
  tools -> team-ts
}

# ── Sovereign daemon ────────────────────────────────

daemon: Sovereign daemon (sovrd) {
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  style.border-radius: 12

  sovrd: sovrd\nline-delimited JSON-RPC\nUnix socket {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 13
    style.bold: true
  }
  principal: EffectivePrincipal\nidentity · vault roots\ncapabilities · read auth {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  retrieval: Hybrid retrieval\nFTS5 + FAISS + rerank\nquery expansion + HyDE {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  candidates: Candidate pipeline\nstage → list → resolve {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  trace: Feedback + trace ring {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  handoff: Inbox/outbox handoff {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  writeback: WriteBackMemory\ndurable learning writes {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  episodic: EpisodicMemory\nevent/task/thread lifecycle {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  safety: Safety\ninstruction injection detector {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  decay: Memory decay\nexponential + access-based {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }
  afm-provider: AFM provider\noff · bridge · native · auto {
    shape: rectangle
    style.fill: "#EEEDFE"
    style.stroke: "#AFA9EC"
    style.font-size: 12
  }

  sovrd -> principal
  principal -> retrieval: read gate
  sovrd -> candidates
  sovrd -> trace
  sovrd -> handoff
  sovrd -> writeback
  sovrd -> episodic
  sovrd -> safety
  retrieval -> afm-provider: query expansion\nHyDE
  candidates -> writeback: on resolve
}

# ── Indexing pipeline ───────────────────────────────

indexing: Indexing pipeline {
  style.fill: "#F8F9FA"
