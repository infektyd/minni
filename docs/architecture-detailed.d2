# ── Connections between groups ──────────────────────

# Surfaces → Plugin
surfaces.codex -> plugin.mcp: {style.stroke: "#85B7EB"}
surfaces.claude -> plugin.mcp: {style.stroke: "#85B7EB"}
surfaces.gemini -> plugin.mcp: {style.stroke: "#85B7EB"}
surfaces.kilocode -> plugin.mcp: {style.stroke: "#85B7EB"}
surfaces.console -> plugin.mcp: {style.stroke: "#85B7EB"}
surfaces.openclaw -> daemon.sovrd: direct (HTTP) {
  style.stroke: "#85B7EB"
  style.stroke-dash: 3
}

# Plugin → Daemon
plugin.tools -> daemon.sovrd: JSON-RPC {style.stroke: "#5DCAA5"}
plugin.hooks -> daemon.sovrd: JSON-RPC {style.stroke: "#5DCAA5"}

# Daemon → Storage
daemon.retrieval -> storage.sqlite: FTS5 queries {style.stroke: "#AFA9EC"}
daemon.retrieval -> storage.vectors: semantic search {style.stroke: "#AFA9EC"}
daemon.handoff -> storage.vaults: writes handoff pages {style.stroke: "#AFA9EC"}
daemon.writeback -> storage.sqlite: durable writes {style.stroke: "#AFA9EC"}
daemon.writeback -> storage.vaults: optional vault sync {style.stroke: "#AFA9EC"; style.stroke-dash: 3}
plugin.tools -> storage.vaults: vault_write tool {style.stroke: "#5DCAA5"; style.stroke-dash: 3}

# Indexing: Vaults → SQLite/FAISS (the missing link)
storage.vaults -> indexing.wiki-indexer: reads vault files {style.stroke: "#97C459"}
indexing.vault-indexer -> storage.sqlite: populates {style.stroke: "#97C459"}
indexing.vault-indexer -> storage.vectors: embeds {style.stroke: "#97C459"}

# Daemon → Compile
daemon.sovrd -> compile.scheduler: {style.stroke: "#AFA9EC"}
daemon.afm-provider -> compile.passes: AFM calls {style.stroke: "#AFA9EC"; style.stroke-dash: 3}
compile.writer -> storage.vaults: review drafts {style.stroke: "#F0997B"; style.stroke-dash: 3}

# Eval (offline, uses retrieval + storage)
daemon.retrieval -> eval.harness: offline eval {style.stroke: "#B4B2A9"; style.stroke-dash: 3}
storage.sqlite -> eval.harness: test queries {style.stroke: "#B4B2A9"; style.stroke-dash: 3}
