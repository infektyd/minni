    style.font-size: 12
  }
  vault-indexer: VaultIndexer\nmarkdown → SQLite + FAISS {
    shape: rectangle
    style.fill: "#EAF3DE"
    style.stroke: "#97C459"
    style.font-size: 12
  }

  wiki-indexer -> vault-indexer
}

