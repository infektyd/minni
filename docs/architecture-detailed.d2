    style.stroke: "#EF9F27"
    style.font-size: 12
  }
}

# ── Compile passes ──────────────────────────────────

compile: Review-only self-organization {
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  style.border-radius: 12

  scheduler: AFM scheduler\nidle-triggered {
    shape: rectangle
    style.fill: "#FAECE7"
    style.stroke: "#F0997B"
    style.font-size: 12
  }
  passes: Compile passes\nsession distillation · synthesis\nprocedure extraction\nreorganization · pruning {
    shape: rectangle
    style.fill: "#FAECE7"
    style.stroke: "#F0997B"
    style.font-size: 12
  }
  writer: AFM writer\ndraft queue → vault pages {
    shape: rectangle
    style.fill: "#FAECE7"
    style.stroke: "#F0997B"
    style.font-size: 12
  }

  scheduler -> passes: triggers
  passes -> writer
}

