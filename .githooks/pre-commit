#!/usr/bin/env bash
# Minni pre-commit hook.
#
# Two gates, in order:
#   1. Public-boundary guard — block staged paths that match .gitignore/.gitfilters
#      (private runtime state, logs, databases, generated output).
#   2. Fast lint gate — venv ruff (engine) + eslint/typecheck (plugin), but only
#      when files in that surface are actually staged. Kept to lint/typecheck
#      (no full test run) so commits stay fast.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Escape hatch (skip both gates):  MINNI_SKIP_HOOKS=1 git commit ...
set -euo pipefail

if [ "${MINNI_SKIP_HOOKS:-0}" = "1" ]; then
  echo "[pre-commit] MINNI_SKIP_HOOKS=1 — skipping guard + lint gates." >&2
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

python3 - <<'PY'
from __future__ import annotations

import fnmatch
import subprocess
import sys
from pathlib import Path


def staged_paths() -> list[str]:
    raw = subprocess.check_output(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR", "-z"]
    )
    if not raw:
        return []
    return [p.decode("utf-8") for p in raw.split(b"\0") if p]


def gitignore_blocks(path: str) -> bool:
    return (
        subprocess.run(
            ["git", "check-ignore", "--quiet", "--no-index", "--", path],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        ).returncode
        == 0
    )


def load_filters() -> list[tuple[str, bool]]:
    filters = Path(".gitfilters")
    if not filters.exists():
        return []

    parsed: list[tuple[str, bool]] = []
    for raw_line in filters.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        allow = line.startswith("!")
        if allow:
            line = line[1:].strip()
        if line:
            parsed.append((line, allow))
    return parsed


def candidates(pattern: str) -> list[str]:
    anchored = pattern.startswith("/")
    pattern = pattern.lstrip("/")
    if pattern.endswith("/"):
        pattern = f"{pattern}**"
    if anchored or "/" in pattern:
        return [pattern]
    return [pattern, f"**/{pattern}"]


def matches(pattern: str, path: str) -> bool:
    return any(fnmatch.fnmatchcase(path, candidate) for candidate in candidates(pattern))


def filter_blocks(path: str, filters: list[tuple[str, bool]]) -> bool:
    blocked = False
    for pattern, allow in filters:
        if matches(pattern, path):
            blocked = not allow
    return blocked


filters = load_filters()
blocked: dict[str, str] = {}

for path in staged_paths():
    if gitignore_blocks(path):
        blocked[path] = "matches .gitignore"
    if filter_blocks(path, filters):
        blocked[path] = "matches .gitfilters"

if blocked:
    print("Minni public-boundary guard blocked this commit.", file=sys.stderr)
    print("These staged paths look like private runtime state, logs, databases, or generated output:", file=sys.stderr)
    for path, reason in sorted(blocked.items()):
        print(f"  - {path} ({reason})", file=sys.stderr)
    print("", file=sys.stderr)
    print("Move durable docs/source into an allowed path, or update .gitfilters only if the file is intentionally public.", file=sys.stderr)
    sys.exit(1)
PY

# ── Gate 2: fast lint/typecheck on touched surfaces ─────────────────────────
staged="$(git diff --cached --name-only --diff-filter=ACMR)"

if echo "$staged" | grep -Eq '^engine/.*\.py$'; then
  echo "[pre-commit] engine Python staged — running ruff…" >&2
  if [ -x engine/.venv/bin/python ]; then
    ( cd engine && .venv/bin/python -m ruff check . )
  else
    echo "[pre-commit] engine/.venv missing — run 'make setup'; skipping engine lint." >&2
  fi
fi

if echo "$staged" | grep -Eq '^plugins/minni/(src|tests)/.*\.(ts|mts|cts|mjs|cjs|js)$'; then
  echo "[pre-commit] plugin sources staged — running eslint + typecheck…" >&2
  if [ -d plugins/minni/node_modules ]; then
    ( cd plugins/minni && npm run --silent lint && npm run --silent typecheck )
  else
    echo "[pre-commit] plugins/minni/node_modules missing — run 'npm ci' there; skipping plugin lint." >&2
  fi
fi

echo "[pre-commit] OK" >&2
