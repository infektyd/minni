{
  "name": "minni",
  "version": "0.1.0",
  "mcpServers": {
    "minni": {
      "command": "node",
      "args": [
        "${extensionPath}${/}..${/}dist${/}server.js"
      ],
      "cwd": "${extensionPath}${/}..",
      "env": {
        "MINNI_AGENT_ID": "gemini",
        "MINNI_VAULT_PATH": "~/.minni/gemini-vault",
        "MINNI_SOCKET_PATH": "~/.minni/run/sovrd.sock"
      }
    }
  }
}
