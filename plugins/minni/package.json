{
  "name": "minni-multi-plugin",
  "version": "0.1.0",
  "description": "Local multi-target plugin bridge for Minni (Codex, Claude Code, Gemini, KiloCode).",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:frontend": "vite build",
    "dev:frontend": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "npm run build && node --test --import ./tests/setup-env.mjs tests/*.test.mjs",
    "coverage": "npm run build:server && node --test --experimental-test-coverage --test-coverage-lines=70 --test-coverage-functions=70 --test-coverage-branches=60 --import ./tests/setup-env.mjs tests/*.test.mjs",
    "test:server": "npm run build:server && node --test --import ./tests/setup-env.mjs tests/*.test.mjs",
    "test:file": "npm run build:server && node --test --import ./tests/setup-env.mjs",
    "console": "npm run build && node dist/ui-server.js",
    "design:lint": "npx @google/design.md lint ../../DESIGN.md",
    "test:live:prepare": "npm run build && node tests/live-prepare-task.mjs",
    "smoke:status": "npm run build && node dist/cli.js status",
    "smoke:hook": "npm run build && node dist/hook.js SessionStart < /dev/null",
    "smoke:kilocode-hook": "npm run build && node dist/kilocode-hook.js SessionStart < /dev/null"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/design.md": "^0.3.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16"
  }
}
