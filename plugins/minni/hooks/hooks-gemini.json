{
  "_comment": "Template for agy. minni-install stamps the absolute native Gemini entrypoint and MINNI_GEMINI_* identity. agy 1.1.1 loads SessionStart through its compatibility layer plus native PreToolUse and Stop. UserPromptSubmit and PreCompact are absent because this host does not dispatch them.",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node __MINNI_GEMINI_DIST__/gemini-hook.js PreToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node __MINNI_GEMINI_DIST__/gemini-hook.js Stop",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node __MINNI_GEMINI_DIST__/gemini-hook.js SessionStart",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
