{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ${KILO_PLUGIN_ROOT}/../dist/kilocode-hook.js SessionStart"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ${KILO_PLUGIN_ROOT}/../dist/kilocode-hook.js UserPromptSubmit"
        }
      ]
    }
