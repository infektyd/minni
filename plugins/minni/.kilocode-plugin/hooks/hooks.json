  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ${KILO_PLUGIN_ROOT}/../dist/kilocode-hook.js PreCompact"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ${KILO_PLUGIN_ROOT}/../dist/kilocode-hook.js Stop"
        }
      ]
    }
  ]
