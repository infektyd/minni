{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${GROK_PLUGIN_ROOT}/bin/grok-minni-hook.js SessionStart",
            "timeout": 8
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${GROK_PLUGIN_ROOT}/bin/grok-minni-hook.js UserPromptSubmit",
            "timeout": 8
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${GROK_PLUGIN_ROOT}/bin/grok-minni-hook.js PreCompact",
            "timeout": 8
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${GROK_PLUGIN_ROOT}/bin/grok-minni-hook.js Stop",
            "timeout": 8
          }
        ]
      }
    ]
  }
}
