/log.md
/index.md

# Root-level Codex audit + index files (mirrored from vault, private)
/log.md
/index.md

# Runtime FAISS index directory (the *.faiss / *.index globs miss .npz)
/faiss/

# Local evaluation and build output
/output/
/reports/

# Cursor IDE workspace state
/.cursor/

# Legacy bundles and local downloads
archives/downloads/
archives/legacy-vaults/

# Wheel-staged plugin payload (release-time only; §4.2)
src/minni/plugin_payload/

# Local plugin build/runtime state
plugins/*/node_modules/
plugins/*/dist/
plugins/*/.env
plugins/*/.playwright-cli/
plugins/.DS_Store
**/.DS_Store


